        {
          "title": "Where Climbed",
          "description": "Where on the tower did the robot climb in autonomous?",
          "type": "select",
          "required": false,
          "code": "endgameClimbPos",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "L1": "L1",
            "L2": "L2",
            "L3": "L3",
            "Side": "On the side"
          }
        },
        {
          "title": "Scoring Effectiveness",
          "description": "Rate the robot's scoring effectiveness.",
          "type": "range",
          "required": false,
          "code": "scoringEff",
          "formResetBehavior": "reset",
          "defaultValue": 3,
          "min": 0,
          "max": 5,
          "step": 1
        },
        {
          "title": "Scored How?",
          "description": "How did the robot score?",
          "type": "select",
          "required": false,
          "code": "scoredHow",
          "formResetBehavior": "reset",
          "defaultValue": "blank",
          "choices": {
            "blank": "(blank)",
            "driving": "While driving",
            "stationary": "While stationary",
            "both": "Both",
            "none": "No scoring"
          }
        },
        {
          "title": "Passing Skill",
          "description": "Rate the robot's passing skill.",
          "type": "range",
          "required": false,
          "code": "passingSkill",
          "formResetBehavior": "reset",
          "defaultValue": 3,
          "min": 0,
