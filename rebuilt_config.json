            "stationary": "While stationary",
            "both": "Both",
            "none": "No Passing"
          }
        },
        {
          "title": "Yellow/Red Card",
          "type": "select",
          "required": true,
          "code": "yc",
          "formResetBehavior": "reset",
          "defaultValue": "No Card",
          "choices": {
            "No Card": "No Card",
            "Yellow": "Yellow Card",
            "Red": "Red Card"
          }
        },
        {
          "title": "Comments",
          "type": "text",
